# shellcheck shell=bash
# versions.env — Canonical Docker image versions for the Personal Genome Pipeline
# This is the single source of truth for all container image tags.
# setup.sh and validate-setup.sh source this file.
#
# To update a tool version:
#   1. Change the tag here
#   2. Run: ./scripts/setup.sh <genome_dir>  (pulls new images)
#   3. Update the corresponding script if it hardcodes the image reference
#
# Images whose publisher offers no versioned tags are pinned by immutable
# digest (name@sha256:...) for reproducibility instead of a floating :latest.
# To refresh one: docker manifest inspect -v <name>:latest | grep -m1 digest
# then update the digest here AND everywhere the image is pulled/run.

# --- Core tools ---
MINIMAP2_IMAGE="quay.io/biocontainers/minimap2:2.31--h118bc1c_0"
SAMTOOLS_IMAGE="staphb/samtools:1.20"
BCFTOOLS_IMAGE="staphb/bcftools:1.21"
DEEPVARIANT_IMAGE="google/deepvariant:1.10.0"
FASTP_IMAGE="quay.io/biocontainers/fastp:1.3.6--h43da1c4_0"

# --- Structural variant callers ---
MANTA_IMAGE="quay.io/biocontainers/manta:1.6.0--h9ee0642_2"
DELLY_IMAGE="quay.io/biocontainers/delly:2.1.0--h3752d28_0"
CNVPYTOR_IMAGE="quay.io/biocontainers/cnvpytor:1.3.2--pyhdfd78af_0"
GRIDSS_IMAGE="quay.io/biocontainers/gridss:2.13.2--h96c455f_6"
DUPHOLD_IMAGE="brentp/duphold:v0.2.3"
ANNOTSV_IMAGE="quay.io/biocontainers/annotsv:3.5.10--hdfd78af_0"

# --- Variant annotation ---
VEP_IMAGE="ensemblorg/ensembl-vep:release_116.0"
PCGR_IMAGE="sigven/pcgr:2.2.5"

# --- Pharmacogenomics ---
PHARMCAT_IMAGE="pgkb/pharmcat:3.2.0"

# --- Specialized analysis ---
TELOMEREHUNTER_IMAGE="lgalarno/telomerehunter@sha256:6d53ac63c3ae50aa036652136c60043fb1e9abfcbbdc7ccd7fdae1fdb3541714"  # digest-pinned; publisher ships no versioned tags (pinned from latest, 2026-07)
HAPLOGREP3_IMAGE="jtb114/haplogrep3@sha256:7b28d98a0ffb801977bcc0597941259cf2c4dbe4e89756a9a2c4809c3c9c78de"  # digest-pinned; publisher ships no versioned tags, genepi/haplogrep3 removed from Docker Hub (pinned from latest, 2026-07)
T1K_IMAGE="quay.io/biocontainers/t1k:1.0.9--h5ca1c30_0"
EXPANSIONHUNTER_IMAGE="quay.io/biocontainers/expansionhunter:5.0.0--hc26b3af_5"
GOLEFT_IMAGE="quay.io/biocontainers/goleft:0.2.6--he881be0_1"
MOSDEPTH_IMAGE="quay.io/biocontainers/mosdepth:0.3.14--h05c3d44_0"

# --- General purpose ---
GATK_IMAGE="broadinstitute/gatk:4.6.2.0"
PICARD_IMAGE="broadinstitute/picard:3.4.0"
PYTHON_IMAGE="python:3.11"
PLINK2_IMAGE="pgscatalog/plink2:2.00a5.10"
MULTIQC_IMAGE="quay.io/biocontainers/multiqc:1.35--pyhdfd78af_1"

# --- v0.4.0: Annotation enrichment ---
VCFANNO_IMAGE="quay.io/biocontainers/vcfanno:0.3.9--h1079eea_0"
# SLIVAR uses staphb/bcftools (BCFTOOLS_IMAGE) + pre-built slivar binary
PYPGX_IMAGE="quay.io/biocontainers/pypgx:0.26.0--pyh7e72e81_0"  # MUST match the pypgx-bundle branch (0.26.0); 0.27.0 mismatched the bundle and pulled pandas 3.0 (broke all genes)

# --- Alternative variant callers ---
OCTOPUS_IMAGE="dancooke/octopus:0.7.4"
CLAIR3_IMAGE="hkubal/clair3:v2.0.2"
SNIFFLES_IMAGE="quay.io/biocontainers/sniffles:2.8.0--pyhdfd78af_0"
STRANGER_IMAGE="quay.io/biocontainers/stranger:0.10.2--pyhdfd78af_0"
