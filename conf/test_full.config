/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config for running full-size tests with real WGS data
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Use: nextflow run main.nf -profile test_full,docker \
           --input samplesheet.csv --reference /path/to/GRCh38.fasta
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    config_profile_name        = 'Full test profile'
    config_profile_description = 'Full-size test dataset to check pipeline results'

    // High ceilings for full-size runs (still bounded for safety)
    max_cpus   = 16
    max_memory = '64.GB'
    max_time   = '48.h'
}
