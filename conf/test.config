/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Stub run (no real data):
        nextflow run main.nf -profile test,docker -stub

    Integration test (requires real genomic data):
        nextflow run main.nf -profile test,docker \
            --input samplesheet.csv \
            --reference /path/to/GRCh38.fasta
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Limit resources for CI
    max_cpus   = 2
    max_memory = '4.GB'
    max_time   = '1.h'

    // Stub inputs — validates pipeline wiring without real genomic data.
    // For integration testing, override input + reference on the command line.
    input      = "${projectDir}/assets/test_samplesheet.csv"
    reference  = "${projectDir}/assets/stub/reference.fasta"
    outdir     = './results_test'

    // Full default tools — stub test exercises all module wiring
    tools = 'pharmcat,cpic,vep,vcfanno,slivar,clinical_filter,cpsr,roh,prs,mito_haplogroup,hla_typing,expansion_hunter,telomere_hunter,mosdepth,mito_variants,cyrius,html_report,multiqc'
}

// Disable trace for CI — some Docker images (e.g. ensembl-vep) run as non-root
// and cannot write .command.trace to the Nextflow work directory on GitHub Actions.
trace.enabled    = false
dag.enabled      = false
