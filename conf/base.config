/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Personal Genome Pipeline — Base resource configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Resource defaults for each process label. Tuned for consumer hardware (16 cores, 64 GB).
    Override in profile-specific configs or with --max_cpus / --max_memory.

    Resources are capped at the configured maximums via the `resourceLimits`
    directive (Nextflow >= 24.04). This replaces the legacy `check_max()`
    helper function, which the strict config parser no longer allows.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {
    // Cap every process at the configured maximums (replaces check_max()).
    resourceLimits = [
        cpus  : params.max_cpus,
        memory: params.max_memory,
        time  : params.max_time
    ]

    // Defaults
    cpus   = 2
    memory = 4.GB
    time   = 4.h

    errorStrategy = { task.exitStatus in [143,137,104,134,139,247] ? 'retry' : 'finish' }
    maxRetries    = 1
    maxErrors     = '-1'

    // Process-specific resources by label
    withLabel: 'process_single' {
        cpus   = 1
        memory = 2.GB
        time   = 2.h
    }
    withLabel: 'process_low' {
        cpus   = 2
        memory = 4.GB
        time   = 4.h
    }
    withLabel: 'process_medium' {
        cpus   = 4
        memory = 8.GB
        time   = 8.h
    }
    withLabel: 'process_high' {
        cpus   = 8
        memory = 32.GB
        time   = 24.h
    }
}
