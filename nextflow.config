/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Personal Genome Pipeline — Nextflow Configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    // ── Input/output ────────────────────────────────────────────────────
    input              = null       // Path to samplesheet CSV
    outdir             = './results'
    publish_dir_mode   = 'copy'

    // ── Reference data ──────────────────────────────────────────────────
    reference          = null       // GRCh38 reference FASTA (required)
    clinvar            = null       // ClinVar pathogenic VCF (optional)
    clinvar_index      = null       // ClinVar pathogenic VCF tabix index

    // ── Genome build ────────────────────────────────────────────────────
    genome             = 'GRCh38'

    // ── Tool selection ──────────────────────────────────────────────────
    // Comma-separated list of analysis tools to run.
    // Default set works without any external databases. Tools that require
    // large downloads are opt-in — add them to --tools once you have the
    // databases in place:
    //   vep,slivar,clinical_filter  (need --vep_cache)
    //   cpsr                        (need --pcgr_data + --vep_cache_cpsr)
    //   expansion_hunter            (need --expansion_catalog)
    //   clinvar                     (need --clinvar + --clinvar_index)
    //   hla_typing                  (need --hla_dat)
    // SV callers and other extras are also opt-in:
    //   manta,delly,cnvnator,duphold,annotsv,survivor_merge,ancestry,pypgx
    tools = 'pharmcat,cpic,vcfanno,roh,prs,mito_haplogroup,telomere_hunter,mosdepth,mito_variants,cyrius,html_report,multiqc'

    // ── Annotation databases (optional — modules skip if not provided) ─
    vep_cache          = null       // VEP offline cache directory (release 112)
    vep_cache_cpsr     = null       // VEP cache for CPSR (release 113, separate)
    pcgr_data          = null       // PCGR/CPSR reference data bundle directory
    pypgx_bundle       = null       // pypgx-bundle reference directory

    // CADD whole-genome pre-scored files
    cadd_snv           = null       // CADD SNV scores (tsv.gz)
    cadd_snv_index     = null       // CADD SNV tabix index
    cadd_indel         = null       // CADD indel scores (tsv.gz)
    cadd_indel_index   = null       // CADD indel tabix index

    // SpliceAI pre-scored files
    spliceai_snv       = null       // SpliceAI SNV VCF (vcf.gz)
    spliceai_snv_index = null       // SpliceAI SNV tabix index
    spliceai_indel     = null       // SpliceAI indel VCF (vcf.gz)
    spliceai_indel_index = null     // SpliceAI indel tabix index

    // Other annotation scores
    revel              = null       // REVEL pathogenicity scores file
    revel_index        = null       // REVEL tabix index
    alphamissense      = null       // AlphaMissense scores file
    alphamissense_index = null      // AlphaMissense tabix index
    gnomad_constraint  = null       // gnomAD gene constraint TSV (LOEUF, pLI)

    // ── Clinical & population genetics ──────────────────────────────────
    pgs_scoring        = null       // PGS Catalog scoring files directory
    ancestry_ref       = null       // Ancestry reference panel
    expansion_catalog  = null       // ExpansionHunter variant catalog JSON
    hla_dat            = null       // Pre-downloaded IPD-IMGT/HLA hla.dat file
    slivar_bin         = null       // Pre-built slivar static binary

    // ── Resource limits ─────────────────────────────────────────────────
    max_memory         = '64.GB'
    max_cpus           = 16
    max_time           = '48.h'
}

// Load base resource config
includeConfig 'conf/base.config'

profiles {
    docker {
        docker.enabled         = true
        docker.runOptions      = '--user root:root'
        singularity.enabled    = false
        conda.enabled          = false
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        conda.enabled          = false
    }
    test {
        includeConfig 'conf/test.config'
    }
    test_full {
        includeConfig 'conf/test_full.config'
    }
}

// Execution reports
def timestamp = new java.text.SimpleDateFormat("yyyy-MM-dd_HH-mm-ss").format(new Date())

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline_${timestamp}.html"
}

report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report_${timestamp}.html"
}

trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace_${timestamp}.txt"
}

dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/dag_${timestamp}.svg"
}

// Manifest
manifest {
    name            = 'Personal-Genome-Pipeline'
    author          = 'GeiserX'
    homePage        = 'https://github.com/GeiserX/Personal-Genome-Pipeline'
    description     = 'Post-processing & clinical interpretation for whole genome sequencing'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '0.5.0'
    defaultBranch   = 'main'
}
