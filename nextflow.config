/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Personal Genome Pipeline — Nextflow Configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    // Input/output
    input              = null       // Path to samplesheet CSV
    outdir             = './results'
    publish_dir_mode   = 'copy'

    // Reference data
    reference          = null       // GRCh38 reference FASTA
    clinvar            = null       // ClinVar pathogenic VCF (optional)
    clinvar_index      = null       // ClinVar pathogenic VCF tabix index

    // Genome build
    genome             = 'GRCh38'

    // Resource limits (override per-environment in conf/)
    max_memory         = '64.GB'
    max_cpus           = 16
    max_time           = '48.h'
}

// Load base resource config
includeConfig 'conf/base.config'

profiles {
    docker {
        docker.enabled         = true
        docker.userEmulation   = true
        singularity.enabled    = false
        conda.enabled          = false
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        conda.enabled          = false
    }
    test {
        includeConfig 'conf/test.config'
    }
    test_full {
        includeConfig 'conf/test_full.config'
    }
}

// Execution reports
def timestamp = new java.text.SimpleDateFormat("yyyy-MM-dd_HH-mm-ss").format(new Date())

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline_${timestamp}.html"
}

report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report_${timestamp}.html"
}

trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace_${timestamp}.txt"
}

dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/dag_${timestamp}.svg"
}

// Manifest
manifest {
    name            = 'Personal-Genome-Pipeline'
    author          = 'GeiserX'
    homePage        = 'https://github.com/GeiserX/Personal-Genome-Pipeline'
    description     = 'Post-processing & clinical interpretation for whole genome sequencing'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '0.5.0'
    defaultBranch   = 'main'
}
